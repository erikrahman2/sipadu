APP_NAME="PA-Disdukcapil System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── MySQL ───────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pa_disdukcapil
DB_USERNAME=root
DB_PASSWORD=secret

# ─── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_HOST=127.0.0.1
NEO4J_PORT=7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jSecret1
NEO4J_DATABASE=neo4j

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=database
QUEUE_RETRY_AFTER=90
QUEUE_MAX_TRIES=3

# ─── Cache / Session ─────────────────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@pa-disdukcapil.go.id"
MAIL_FROM_NAME="${APP_NAME}"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

# ─── OCR Microservice ────────────────────────────────────────────────────────
OCR_SERVICE_URL=http://localhost:5001
OCR_SECRET_KEY=ocr_secret_key_change_in_production
OCR_TIMEOUT=60
OCR_LANG=ind+eng
TESSERACT_CMD="C:\Program Files\Tesseract-OCR\tesseract.exe"
TESSDATA_PREFIX="D:\ProyekTA\ocr-service\tessdata"

# ─── Storage ─────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
DOCUMENT_DISK=local

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_OCR=20

# ─── Security ────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
TRUSTED_PROXIES=
TLS_FORCE=false
